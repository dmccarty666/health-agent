+/* ================================================================
+   BODY MAP — Stats Bar, Toggles, SVG, Legend, Segments
+   ================================================================ */
+
+/* Top stats bar row */
+.body-map-stats {
+  display: grid;
+  grid-template-columns: repeat(4, 1fr);
+  gap: 0.5rem;
+  margin-bottom: 1rem;
+}
+
+@media (max-width: 768px) {
+  .body-map-stats {
+    grid-template-columns: repeat(2, 1fr);
+  }
+}
+
+.body-map-stat {
+  display: flex;
+  align-items: center;
+  gap: 0.375rem;
+  padding: 0.5rem 0.625rem;
+  border-radius: 0.375rem;
+  background: hsl(var(--card));
+  border: 1px solid hsl(var(--border));
+  font-size: 0.6875rem;
+}
+
+.body-map-stat-label {
+  color: hsl(var(--muted-foreground));
+  white-space: nowrap;
+}
+
+.body-map-stat-value {
+  margin-left: auto;
+  font-family: 'JetBrains Mono', 'Courier New', monospace;
+  font-weight: 600;
+  font-size: 0.8125rem;
+  color: hsl(var(--foreground));
+}
+
+.body-map-stat-unit {
+  font-weight: 400;
+  font-size: 0.625rem;
+  color: hsl(var(--muted-foreground));
+  margin-left: 1px;
+}
+
+/* View mode toggle pills */
+.body-map-toggles {
+  display: flex;
+  gap: 0.375rem;
+  margin-bottom: 1rem;
+  flex-wrap: wrap;
+}
+
+.body-map-toggle {
+  padding: 0.375rem 0.75rem;
+  font-size: 0.6875rem;
+  font-weight: 500;
+  border: 1px solid hsl(var(--border));
+  border-radius: 1rem;
+  background: hsl(var(--card));
+  color: hsl(var(--muted-foreground));
+  cursor: pointer;
+  transition: all 0.15s;
+  font-family: inherit;
+}
+
+.body-map-toggle:hover {
+  border-color: hsl(var(--primary));
+  color: hsl(var(--foreground));
+}
