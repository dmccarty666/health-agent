+"""FizzBuzz implementation.
+
+Returns a list of strings for numbers 1..n, replacing:
+  - multiples of 3 with "Fizz"
+  - multiples of 5 with "Buzz"
+  - multiples of both with "FizzBuzz"
+"""
+
+
+def fizzbuzz(n: int) -> list[str]:
+    """Return FizzBuzz sequence for numbers 1..n.
+
+    Args:
+        n: Upper bound (inclusive) of the sequence.
+
+    Returns:
+        List of strings with FizzBuzz replacements applied.
+
+    Raises:
+        ValueError: If n is less than 1.
+    """
+    if n < 1:
+        raise ValueError("n must be >= 1")
+
+    result: list[str] = []
+    for i in range(1, n + 1):
+        if i % 15 == 0:
+            result.append("FizzBuzz")
+        elif i % 3 == 0:
+            result.append("Fizz")
+        elif i % 5 == 0:
+            result.append("Buzz")
+        else:
+            result.append(str(i))
+    return result
