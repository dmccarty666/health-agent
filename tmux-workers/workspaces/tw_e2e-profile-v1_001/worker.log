+"""Pytest tests for fizzbuzz."""
+
+import sys
+import pytest
+
+# Ensure /tmp is importable
+sys.path.insert(0, "/tmp")
+
+from fizzbuzz_pf import fizzbuzz  # noqa: E402
+
+
+class TestFizzBuzz:
+    """Test suite for the fizzbuzz function."""
+
+    def test_n_1(self) -> None:
+        """n=1 returns just ['1']."""
+        assert fizzbuzz(1) == ["1"]
+
+    def test_n_15(self) -> None:
+        """n=15 returns the classic FizzBuzz sequence up to 15."""
+        expected = [
+            "1", "2", "Fizz", "4", "Buzz",
+            "Fizz", "7", "8", "Fizz", "Buzz",
+            "11", "Fizz", "13", "14", "FizzBuzz",
+        ]
+        assert fizzbuzz(15) == expected
+
+    def test_n_30(self) -> None:
+        """n=30 returns correct sequence including two FizzBuzz entries."""
+        result = fizzbuzz(30)
+        assert len(result) == 30
+        assert result[0] == "1"
+        assert result[2] == "Fizz"       # 3
+        assert result[4] == "Buzz"       # 5
+        assert result[14] == "FizzBuzz"  # 15
+        assert result[29] == "FizzBuzz"  # 30
+
+    def test_zero_raises(self) -> None:
+        """n=0 raises ValueError."""
+        with pytest.raises(ValueError, match="n must be >= 1"):
+            fizzbuzz(0)
+
+    def test_negative_raises(self) -> None:
+        """Negative n raises ValueError."""
+        with pytest.raises(ValueError, match="n must be >= 1"):
+            fizzbuzz(-5)
