+"""Tests for fizzbuzz_v5 — covers n=1, n=15, n=30."""
+
+import sys
+
+import pytest
+
+sys.path.insert(0, "/tmp")
+from fizzbuzz_v5 import fizzbuzz  # noqa: E402
+
+
+def test_fizzbuzz_n1() -> None:
+    """n=1: single element list."""
+    result = fizzbuzz(1)
+    assert result == ["1"]
+
+
+def test_fizzbuzz_n15() -> None:
+    """n=15: full FizzBuzz cycle with first FizzBuzz at position 15."""
+    result = fizzbuzz(15)
+    expected = [
+        "1", "2", "Fizz", "4", "Buzz", "Fizz", "7", "8",
+        "Fizz", "Buzz", "11", "Fizz", "13", "14", "FizzBuzz",
+    ]
+    assert result == expected
+    # Spot checks
+    assert result[2] == "Fizz"       # 3
+    assert result[4] == "Buzz"       # 5
+    assert result[14] == "FizzBuzz"  # 15
+
+
+def test_fizzbuzz_n30() -> None:
+    """n=30: two FizzBuzz entries (15 and 30)."""
+    result = fizzbuzz(30)
+    assert len(result) == 30
+    assert result[14] == "FizzBuzz"  # 15
+    assert result[29] == "FizzBuzz"  # 30
+    # Verify all Fizz positions
+    for i, val in enumerate(result, start=1):
+        if i % 3 == 0 and i % 5 == 0:
+            assert val == "FizzBuzz", f"Position {i}: expected FizzBuzz, got {val}"
+        elif i % 3 == 0:
+            assert val == "Fizz", f"Position {i}: expected Fizz, got {val}"
+        elif i % 5 == 0:
+            assert val == "Buzz", f"Position {i}: expected Buzz, got {val}"
+        else:
+            assert val == str(i), f"Position {i}: expected {i}, got {val}"
+
+
+def test_fizzbuzz_raises_on_bad_input() -> None:
+    """n < 1 should raise ValueError."""
+    with pytest.raises(ValueError, match="n must be >= 1"):
+        fizzbuzz(0)
+    with pytest.raises(ValueError, match="n must be >= 1"):
+        fizzbuzz(-5)
