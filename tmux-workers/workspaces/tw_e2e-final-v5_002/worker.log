+"""FizzBuzz implementation — returns list of strings for 1..n.
+
+Multiples of 3 → "Fizz", multiples of 5 → "Buzz",
+multiples of both 3 and 5 → "FizzBuzz", otherwise the number as a string.
+"""
+
+from typing import List
+
+
+def fizzbuzz(n: int) -> List[str]:
+    """Return FizzBuzz output for numbers 1 through n.
+
+    Args:
+        n: Upper bound (inclusive), must be >= 1.
+
+    Returns:
+        List of strings representing the FizzBuzz sequence.
+    """
+    if n < 1:
+        raise ValueError(f"n must be >= 1, got {n}")
+
+    result: List[str] = []
+    for i in range(1, n + 1):
+        if i % 3 == 0 and i % 5 == 0:
+            result.append("FizzBuzz")
+        elif i % 3 == 0:
+            result.append("Fizz")
+        elif i % 5 == 0:
+            result.append("Buzz")
+        else:
+            result.append(str(i))
+    return result
